# Copy to `.env.local` in this folder if you run `npm run dev` from sites/aspen-country.
# Main app at repo root uses the root `.env.local` / Vercel env instead.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_TENANT_ID=

# WordPress headless CMS (must match Vercel / root .env for production)
WORDPRESS_BASE_URL=https://lightslategrey-goose-295226.hostingersite.com
NEXT_PUBLIC_WORDPRESS_BASE_URL=https://lightslategrey-goose-295226.hostingersite.com
WORDPRESS_REVALIDATE_SECONDS=300
WORDPRESS_LISTING_REST_BASE=listing
WORDPRESS_TESTIMONIAL_REST_BASE=testimonial
NEXT_PUBLIC_WORDPRESS_LISTING_POST_TYPE=listing
NEXT_PUBLIC_WORDPRESS_TESTIMONIAL_POST_TYPE=testimonial
