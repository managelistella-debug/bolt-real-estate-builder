# Copy to `.env.local` for local development.
# On Vercel: add the same keys under Project → Settings → Environment Variables.

# -----------------------------------------------------------------------------
# WordPress headless CMS (listings, blog posts, testimonials via REST API)
# -----------------------------------------------------------------------------
WORDPRESS_BASE_URL=https://lightslategrey-goose-295226.hostingersite.com
NEXT_PUBLIC_WORDPRESS_BASE_URL=https://lightslategrey-goose-295226.hostingersite.com

# Cache: how often Next.js revalidates WordPress fetches (seconds)
WORDPRESS_REVALIDATE_SECONDS=300

# REST path after /wp/v2/ — must match your CPT `rest_base` in WordPress
WORDPRESS_LISTING_REST_BASE=listing
WORDPRESS_TESTIMONIAL_REST_BASE=testimonial

# wp-admin edit URLs (post type slugs in WordPress)
NEXT_PUBLIC_WORDPRESS_LISTING_POST_TYPE=listing
NEXT_PUBLIC_WORDPRESS_TESTIMONIAL_POST_TYPE=testimonial

# -----------------------------------------------------------------------------
# Supabase (optional — used when WORDPRESS_BASE_URL is unset or for other features)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_TENANT_ID=
